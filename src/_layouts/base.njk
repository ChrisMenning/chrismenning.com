<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — Chris Menning</title>
  <meta name="description" content="{{ description or 'Software developer, electronic musician, maker. Green Bay, WI.' }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,300;0,400;0,600;0,700;0,900;1,300&family=Share+Tech+Mono&family=Oxanium:wght@400;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/css/main.css' | url }}">
</head>
<body>

<a class="skip-link" href="#main-content">Skip to content</a>
<div class="stripe stripe-full" role="presentation" aria-hidden="true"></div>

<header>
  <nav class="site-nav" aria-label="Main navigation">
    <div class="nav-inner">
      <a href="{{ '/' | url }}" class="nav-logo" aria-label="Chris Menning — home">
        <svg class="nav-logo-mark" viewBox="0 0 44 22" fill="none" aria-hidden="true">
          <polyline points="1,11 7,11 11,3 15,19 19,11 25,11 29,3 33,19 37,11 43,11"
            stroke="#d4a820" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="nav-logo-name">Chris Menning</span>
      </a>
      <ul class="nav-links" role="list">
        <li class="nav-item-mega">
          <a href="{{ '/projects/' | url }}" class="nav-mega-trigger" aria-haspopup="true" aria-expanded="false">
            Projects <span class="nav-mega-caret" aria-hidden="true">&#9662;</span>
          </a>
          <div class="nav-mega-panel" hidden>
            <div class="nav-mega-inner">
              <div class="nav-mega-col nav-mega-col-all">
                <div class="nav-mega-heading">Browse</div>
                <a href="{{ '/projects/' | url }}" class="nav-mega-link nav-mega-link-all">All Projects</a>
              </div>
              <div class="nav-mega-col">
                <div class="nav-mega-heading">By Discipline</div>
                <a href="{{ '/tags/software/' | url }}" class="nav-mega-link">Software</a>
                <a href="{{ '/tags/hardware/' | url }}" class="nav-mega-link">Hardware</a>
                <a href="{{ '/tags/music/' | url }}" class="nav-mega-link">Music</a>
                <a href="{{ '/tags/open-source/' | url }}" class="nav-mega-link">Open Source</a>
                <a href="{{ '/tags/vr/' | url }}" class="nav-mega-link">VR</a>
                <a href="{{ '/tags/nature/' | url }}" class="nav-mega-link">Nature</a>
                <a href="{{ '/tags/home-lab/' | url }}" class="nav-mega-link">Home Lab</a>
                <a href="{{ '/tags/web/' | url }}" class="nav-mega-link">Web</a>
              </div>
              <div class="nav-mega-col nav-mega-col-skills">
                <div class="nav-mega-heading">By Skill</div>
                <div class="nav-mega-skills">
                  {%- for group in skillGroups %}
                  <div class="nav-mega-skill-group">
                    <div class="nav-mega-skill-label">{{ group.label }}</div>
                    {%- for skill in group.skills %}
                    <a href="{{ ('/skills/' + skill.id + '/') | url }}" class="nav-mega-link">{{ skill.label }}</a>
                    {%- endfor %}
                  </div>
                  {%- endfor %}
                </div>
              </div>
            </div>
          </div>
        </li>
        <li><a href="{{ '/about/' | url }}">About</a></li>
        <li><a href="{{ '/contact/' | url }}">Contact</a></li>
      </ul>
    </div>
  </nav>
</header>

{{ content | safe }}

<footer class="site-footer">
  <div class="stripe stripe-medium" role="presentation" aria-hidden="true"></div>
  <div class="footer-inner">
    <p class="footer-copy">© CHRIS MENNING · GREEN BAY, WI · CHRISMENNING.COM</p>
    <ul class="footer-links" aria-label="External links" role="list">
      <li><a href="https://github.com/chrismenning" rel="noopener noreferrer" aria-label="GitHub">GitHub</a></li>
      <li><a href="https://disasterpreparednessclub.bandcamp.com" rel="noopener noreferrer" aria-label="Bandcamp">Bandcamp</a></li>
      <li><a href="https://linkedin.com/in/chrismenning" rel="noopener noreferrer" aria-label="LinkedIn">LinkedIn</a></li>
      <li><a href="https://mastodon.social/@chrismenning" rel="noopener noreferrer" aria-label="Mastodon">Mastodon</a></li>
    </ul>
  </div>
</footer>

<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Image lightbox" hidden>
  <button class="lightbox-close" id="lightbox-close" aria-label="Close image">&times;</button>
  <img class="lightbox-img" id="lightbox-img" alt="">
</div>

<script>
(function () {
  var lb = document.getElementById('lightbox');
  var lbImg = document.getElementById('lightbox-img');
  var lbClose = document.getElementById('lightbox-close');

  function open(img) {
    lbImg.src = img.src;
    lbImg.alt = img.alt;
    lb.hidden = false;
    document.body.style.overflow = 'hidden';
    lbClose.focus();
  }

  function close() {
    lb.hidden = true;
    lbImg.src = '';
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.project-figure img').forEach(function (img) {
    img.addEventListener('click', function () { open(img); });
  });

  lbClose.addEventListener('click', close);

  lb.addEventListener('click', function (e) {
    if (e.target === lb) close();
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !lb.hidden) close();
  });
}());
</script>

<script>
(function () {
  // Mega menu
  var megaItem = document.querySelector('.nav-item-mega');
  if (megaItem) {
    var megaTrigger = megaItem.querySelector('.nav-mega-trigger');
    var megaPanel   = megaItem.querySelector('.nav-mega-panel');
    var hoverTimer;

    function openMega() {
      clearTimeout(hoverTimer);
      megaPanel.hidden = false;
      megaTrigger.setAttribute('aria-expanded', 'true');
    }
    function closeMega() {
      megaPanel.hidden = true;
      megaTrigger.setAttribute('aria-expanded', 'false');
    }
    function closeMegaDelayed() {
      hoverTimer = setTimeout(closeMega, 120);
    }

    megaItem.addEventListener('mouseenter', openMega);
    megaItem.addEventListener('mouseleave', closeMegaDelayed);
    megaTrigger.addEventListener('focus', openMega);
    megaItem.addEventListener('focusout', function (e) {
      if (!megaItem.contains(e.relatedTarget)) closeMega();
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !megaPanel.hidden) {
        closeMega();
        megaTrigger.focus();
      }
    });
  }

  // Sort + filter (projects page only)
  var grid = document.querySelector('.project-grid');
  if (!grid) return;

  var activeSort = 'year';
  var activeSkill = '';
  var activeDiscipline = '';

  function applyAll() {
    var cards = Array.from(grid.querySelectorAll('.project-card'));
    cards.forEach(function (card) {
      var show = true;
      if (activeSkill) {
        var skills = (card.dataset.skills || '').split(' ').filter(Boolean);
        if (skills.indexOf(activeSkill) === -1) show = false;
      }
      if (activeDiscipline) {
        var disciplines = (card.dataset.disciplines || '').split(' ').filter(Boolean);
        if (disciplines.indexOf(activeDiscipline) === -1) show = false;
      }
      card.hidden = !show;
    });
    cards.sort(function (a, b) {
      if (activeSort === 'alpha') {
        return (a.dataset.title || '').localeCompare(b.dataset.title || '');
      }
      return parseInt(b.dataset.year, 10) - parseInt(a.dataset.year, 10);
    });
    cards.forEach(function (card) { grid.appendChild(card); });
  }

  // Sort buttons (exclude filter-drop-btn which also carries sort-btn class)
  document.querySelectorAll('.sort-btn:not(.filter-drop-btn)').forEach(function (btn) {
    btn.addEventListener('click', function () {
      activeSort = btn.dataset.sort;
      document.querySelectorAll('.sort-btn:not(.filter-drop-btn)').forEach(function (b) {
        var active = b === btn;
        b.classList.toggle('sort-btn-active', active);
        b.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
      applyAll();
    });
  });

  // Custom filter dropdowns
  function closeAllDrops() {
    document.querySelectorAll('.filter-drop-btn').forEach(function (b) {
      b.setAttribute('aria-expanded', 'false');
    });
    document.querySelectorAll('.filter-drop-panel').forEach(function (p) {
      p.hidden = true;
    });
  }

  document.querySelectorAll('.filter-drop').forEach(function (drop) {
    var btn = drop.querySelector('.filter-drop-btn');
    var panel = drop.querySelector('.filter-drop-panel');
    var label = btn.querySelector('.filter-drop-label');
    var filterKey = drop.dataset.filter;
    var defaultLabel = label.textContent;

    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      var isOpen = btn.getAttribute('aria-expanded') === 'true';
      closeAllDrops();
      if (!isOpen) {
        btn.setAttribute('aria-expanded', 'true');
        panel.hidden = false;
      }
    });

    panel.querySelectorAll('.filter-opt').forEach(function (opt) {
      opt.addEventListener('click', function () {
        var val = opt.dataset.val;
        panel.querySelectorAll('.filter-opt').forEach(function (o) {
          o.classList.toggle('filter-opt-active', o === opt);
          o.setAttribute('aria-selected', o === opt ? 'true' : 'false');
        });
        label.textContent = val ? opt.textContent.trim() : defaultLabel;
        btn.classList.toggle('sort-btn-active', !!val);
        if (filterKey === 'discipline') activeDiscipline = val;
        if (filterKey === 'skill') activeSkill = val;
        closeAllDrops();
        applyAll();
      });
    });
  });

  document.addEventListener('click', function (e) {
    if (!e.target.closest('.filter-drop')) closeAllDrops();
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeAllDrops();
  });
}());
</script>

</body>
</html>
