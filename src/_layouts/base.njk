<div class="stripe stripe-full" role="presentation" aria-hidden="true"></div>

<header>
  <nav class="site-nav" aria-label="Main navigation">
    <div class="nav-inner">
      <a href="{{ '/' | url }}" class="nav-logo" aria-label="Chris Menning — home">
        <svg class="nav-logo-mark" viewBox="0 0 44 22" fill="none" aria-hidden="true">
          <polyline points="1,11 7,11 11,3 15,19 19,11 25,11 29,3 33,19 37,11 43,11"
            stroke="#d4a820" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="nav-logo-name">Chris Menning</span>
      </a>
      <ul class="nav-links" role="list">
        <li><a href="{{ '/projects/' | url }}">Projects</a></li>
        <li><a href="{{ '/about/' | url }}">About</a></li>
        <li><a href="{{ '/contact/' | url }}">Contact</a></li>
      </ul>
    </div>
    <div class="nav-filter" aria-label="Browse by discipline">
      <a href="{{ '/tags/software/' | url }}">Software</a>
      <a href="{{ '/tags/hardware/' | url }}">Hardware</a>
      <a href="{{ '/tags/music/' | url }}">Music</a>
      <a href="{{ '/tags/open-source/' | url }}">Open Source</a>
      <a href="{{ '/tags/vr/' | url }}">VR</a>
