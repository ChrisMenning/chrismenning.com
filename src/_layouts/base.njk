<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — Chris Menning</title>
  <meta name="description" content="{{ description or 'Software developer, electronic musician, maker. Green Bay, WI.' }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,300;0,400;0,600;0,700;0,900;1,300&family=Share+Tech+Mono&family=Oxanium:wght@400;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>

<a class="skip-link" href="#main-content">Skip to content</a>
<div class="stripe stripe-full" role="presentation" aria-hidden="true"></div>

<header>
  <nav class="site-nav" aria-label="Main navigation">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Chris Menning — home">
        <svg class="nav-logo-mark" viewBox="0 0 44 22" fill="none" aria-hidden="true">
          <polyline points="1,11 7,11 11,3 15,19 19,11 25,11 29,3 33,19 37,11 43,11"
            stroke="#d4a820" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="nav-logo-name">Chris Menning</span>
      </a>
      <ul class="nav-links" role="list">
        <li><a href="/projects/">Projects</a></li>
        <li><a href="/about/">About</a></li>
        <li><a href="/contact/">Contact</a></li>
      </ul>
    </div>
  </nav>
</header>

{{ content | safe }}

<footer class="site-footer">
  <div class="stripe stripe-medium" role="presentation" aria-hidden="true"></div>
  <div class="footer-inner">
    <p class="footer-copy">© CHRIS MENNING · GREEN BAY, WI · CHRISMENNING.COM</p>
    <ul class="footer-links" aria-label="External links" role="list">
      <li><a href="https://github.com/chrismenning" rel="noopener noreferrer" aria-label="GitHub">GitHub</a></li>
      <li><a href="https://disasterpreparednessclub.bandcamp.com" rel="noopener noreferrer" aria-label="Bandcamp">Bandcamp</a></li>
      <li><a href="https://linkedin.com/in/chrismenning" rel="noopener noreferrer" aria-label="LinkedIn">LinkedIn</a></li>
      <li><a href="https://mastodon.social/@chrismenning" rel="noopener noreferrer" aria-label="Mastodon">Mastodon</a></li>
    </ul>
  </div>
</footer>

</body>
</html>
