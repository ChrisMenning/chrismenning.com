---
layout: base.njk
---

<main id="main-content">

  <div class="page-hero" aria-label="{{ title }}">
    <div class="page-hero-inner">
      <div class="page-eyebrow" aria-hidden="true">{{ order | padZero }} // Projects</div>
      <h1 class="page-heading">{{ title }}</h1>
      <div class="page-stripe" aria-hidden="true"></div>
    </div>
  </div>

  <div class="page-body">
    <div class="project-detail-layout">

      <div>
        <a href="{{ '/projects/' | url }}" class="project-back" aria-label="Back to all projects">Back to projects</a>
        <div class="project-content">
          {{ content | safe }}
        </div>
      </div>

      <aside class="project-detail-sidebar" aria-label="Project details">

        <div class="hud-panel">
          <div class="panel-header">
            <span class="panel-header-label">// metadata</span>
            <div class="led-row" aria-hidden="true">
              {%- if status == "complete" %}
              <div class="led led-g"></div><div class="led led-g"></div><div class="led led-off"></div>
              {%- elif status == "ongoing" %}
              <div class="led led-g"></div><div class="led led-y"></div><div class="led led-off"></div>
              {%- else %}
              <div class="led led-y"></div><div class="led led-off"></div><div class="led led-off"></div>
              {%- endif %}
            </div>
          </div>
          <div class="panel-body">
            <div class="panel-hazard-strip" aria-hidden="true"></div>
            <div class="panel-section">
              <div class="panel-label">// year · status</div>
              <div class="bio-meta">
                <span class="tape tape-r1">{{ year }}</span>
                <span class="tape tape-r2">{{ status }}</span>
              </div>
            </div>
            <div class="panel-rule" aria-hidden="true"></div>
            <div class="panel-section">
              <div class="panel-label">// disciplines</div>
              <div class="tags">
                {%- for tag in projectTags %}
                <span class="tag tag-{{ tag }}">{{ tag | tagName }}</span>
                {%- endfor %}
              </div>
            </div>
            {%- if website or github or bandcamp or meta %}
            <div class="panel-rule" aria-hidden="true"></div>
            <div class="panel-section">
              <div class="panel-label">// links</div>
              <div class="lcd">
                {%- if website %}<a href="{{ website }}" rel="noopener noreferrer" style="color:#88ffb0;text-decoration:none;" aria-label="Project website">Website →</a><br>{%- endif %}
                {%- if github %}<a href="{{ github }}" rel="noopener noreferrer" style="color:#88ffb0;text-decoration:none;" aria-label="GitHub repository">GitHub →</a><br>{%- endif %}
                {%- if bandcamp %}<a href="{{ bandcamp }}" rel="noopener noreferrer" style="color:#88ffb0;text-decoration:none;" aria-label="Bandcamp">Bandcamp →</a><br>{%- endif %}
                {%- if meta %}<a href="{{ meta }}" rel="noopener noreferrer" style="color:#88ffb0;text-decoration:none;" aria-label="Meta Horizon Store">Meta Store →</a>{%- endif %}
              </div>
            </div>
            {%- endif %}
          </div>
          <div class="panel-footer-stripe" aria-hidden="true"></div>
        </div>

      </aside>

    </div>
  </div>

</main>
