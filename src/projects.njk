---
layout: base.njk
title: Projects
permalink: /projects/
description: Software, hardware, and music projects by Chris Menning.
---

<main id="main-content">

  <div class="page-hero" aria-label="Projects">
    <div class="page-hero-inner">
      <div class="page-eyebrow" aria-hidden="true">02 // Work</div>
      <h1 class="page-heading">Projects</h1>
      <div class="page-stripe" aria-hidden="true"></div>
      <p class="page-desc">Software, hardware, music. Things I built because they didn't exist, or because I wanted to understand how they worked.</p>
    </div>
  </div>

  <div class="page-body">
    <div class="project-grid">
      {%- for project in collections.projects | sort(false, false, "data.order") %}
      <a href="{{ project.url | url }}" class="project-card" aria-label="{{ project.data.title }}">
        <div class="project-card-num">{{ project.data.order | padZero }} //</div>
        <div class="project-card-title">{{ project.data.title }}</div>
        <div class="project-card-meta">
          <span class="tape tape-r1">{{ project.data.year }}</span>
          <span class="tape {% if loop.index % 3 == 0 %}tape-r3{% elif loop.index % 2 == 0 %}tape-r2{% else %}tape-r1{% endif %}">{{ project.data.status }}</span>
        </div>
        <div class="project-card-body">{{ project.data.summary }}</div>
        <div class="project-card-footer">
          <div class="tags">
            {%- for tag in project.data.projectTags %}
            <span class="tag tag-{{ tag }}">{{ tag | tagName }}</span>
            {%- endfor %}
          </div>
          <span class="project-status project-status-{{ project.data.status }}" aria-label="Status: {{ project.data.status }}">
            {%- if project.data.status == "complete" %}● Complete
            {%- elif project.data.status == "ongoing" %}● Ongoing
            {%- elif project.data.status == "paused" %}● Paused
            {%- endif %}
          </span>
        </div>
      </a>
      {%- endfor %}
    </div>
  </div>

</main>
