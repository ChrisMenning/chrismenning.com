---
layout: base.njk
title: Projects
permalink: /projects/
description: Software, hardware, and music projects by Chris Menning.
---

<main id="main-content">

  <div class="page-hero" aria-label="Projects">
    <div class="page-hero-inner">
      <div class="page-eyebrow" aria-hidden="true">02 // Work</div>
      <h1 class="page-heading">Projects</h1>
      <div class="page-stripe" aria-hidden="true"></div>
      <p class="page-desc">Software, hardware, music. Things I built because they didn't exist, or because I wanted to understand how they worked.</p>
    </div>
  </div>

  <div class="page-body">
    <div class="sort-toolbar" role="toolbar" aria-label="Sort and filter">
      <span class="sort-toolbar-label">Sort</span>
      <button class="sort-btn sort-btn-active" data-sort="year" aria-pressed="true">// by year</button>
      <button class="sort-btn" data-sort="alpha" aria-pressed="false">// A–Z</button>
      <span class="toolbar-sep" aria-hidden="true">/</span>
      <span class="sort-toolbar-label">Filter</span>
      <div class="filter-drop" data-filter="discipline">
        <button class="sort-btn filter-drop-btn" aria-expanded="false" aria-haspopup="listbox" aria-label="Filter by discipline">
          <span class="filter-drop-label">// discipline</span> <span class="filter-drop-caret" aria-hidden="true">▾</span>
        </button>
        <div class="filter-drop-panel" role="listbox" aria-label="Filter by discipline" hidden>
          <button class="filter-opt filter-opt-active" role="option" aria-selected="true" data-val="">// all</button>
          <button class="filter-opt" role="option" aria-selected="false" data-val="software">Software</button>
          <button class="filter-opt" role="option" aria-selected="false" data-val="hardware">Hardware</button>
          <button class="filter-opt" role="option" aria-selected="false" data-val="music">Music</button>
          <button class="filter-opt" role="option" aria-selected="false" data-val="open-source">Open Source</button>
          <button class="filter-opt" role="option" aria-selected="false" data-val="vr">VR</button>
          <button class="filter-opt" role="option" aria-selected="false" data-val="nature">Nature</button>
          <button class="filter-opt" role="option" aria-selected="false" data-val="home-lab">Home Lab</button>
          <button class="filter-opt" role="option" aria-selected="false" data-val="web">Web</button>
        </div>
      </div>
      <div class="filter-drop" data-filter="skill">
        <button class="sort-btn filter-drop-btn" aria-expanded="false" aria-haspopup="listbox" aria-label="Filter by skill">
          <span class="filter-drop-label">// skill</span> <span class="filter-drop-caret" aria-hidden="true">▾</span>
        </button>
        <div class="filter-drop-panel" role="listbox" aria-label="Filter by skill" hidden>
          <button class="filter-opt filter-opt-active" role="option" aria-selected="true" data-val="">// all</button>
          {%- for group in skillGroups %}
          <div class="filter-opt-group">{{ group.label }}</div>
          {%- for skill in group.skills %}
          <button class="filter-opt" role="option" aria-selected="false" data-val="{{ skill.id }}">{{ skill.label }}</button>
          {%- endfor %}
          {%- endfor %}
        </div>
      </div>
    </div>
    <div class="project-grid">
      {%- for project in collections.projects | sort(true, false, "data.year") %}
      <div class="project-card"
        data-year="{{ project.data.year }}"
        data-title="{{ project.data.title | lower }}"
        data-skills="{{ project.data.skills | join(' ') }}"
        data-disciplines="{{ project.data.projectTags | join(' ') }}"
      >
        <div class="project-card-num">
          <span class="project-card-num-index">{{ project.data.year }}</span>
          <span class="project-status project-status-{{ project.data.status }}" aria-label="Status: {{ project.data.status }}">
            {%- if project.data.status == "complete" %}● Complete
            {%- elif project.data.status == "ongoing" %}● Ongoing
            {%- elif project.data.status == "paused" %}● Paused
            {%- endif %}
          </span>
        </div>
        <a href="{{ project.url | url }}" class="project-card-title project-card-link" aria-label="{{ project.data.title }}">{{ project.data.title }}</a>
        <div class="project-card-body">{{ project.data.summary }}</div>
        <div class="project-card-footer">
          <div class="tags">
            {%- for tag in project.data.projectTags %}
            <a href="{{ ('/tags/' + tag) | url }}" class="tag tag-{{ tag }}" aria-label="Browse {{ tag | tagName }} projects">{{ tag | tagName }}</a>
            {%- endfor %}
          </div>
        </div>
      </div>
      {%- endfor %}
    </div>
  </div>

</main>
