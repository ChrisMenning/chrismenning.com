---
layout: base.njk
title: Developer & Maker
description: Software developer, electronic musician, maker. Green Bay, WI.
---

<main id="main-content">
<section class="hero" aria-label="Introduction">

  <div class="hero-grid" aria-hidden="true"></div>
  <div class="hero-wash" aria-hidden="true"></div>
  <div class="hero-ghost" aria-hidden="true">Menning</div>

  <div class="hud-catalog" aria-hidden="true">
    <strong>REF //</strong> CM-2025<br>
    <strong>ISS //</strong> v1.0<br>
    <strong>LOC //</strong> Green Bay, WI
  </div>

  <div class="hud-status" aria-label="Current status">
    <span class="dim">STATUS // </span><span class="online">OPERATIONAL</span><br>
    <span class="dim">AVAIL  // </span><span class="online">OPEN</span><br>
    <span class="dim">PREF    // </span><span class="online">SELF-HOSTED</span>
  </div>

  <div class="hud">

    <div class="hud-name-block">
      <div class="hud-eyebrow" aria-hidden="true">
        Software Developer · Electronic Musician
      </div>
      <h1 class="hud-name">Chris<br><span class="gold">Menning</span></h1>
      <div class="hud-name-stripe" aria-hidden="true"></div>
    </div>

    <div class="hud-bottom">

      <div class="hud-bio">
        <p>Technology that puts people in control of their own information — not platforms, not vendors — is the interest underneath all of it. I write software, make music on vintage gear I own outright, and run <strong>self-hosted</strong> infrastructure that doesn't report back to anyone. The work is varied. The instinct toward open systems and data ownership is consistent.</p>
        <div class="bio-meta" aria-label="Disciplines">
          <span class="tape tape-r1">C# · .NET</span>
          <span class="tape tape-r2">Salesforce Apex</span>
          <span class="tape tape-r3">DAWless</span>
          <span class="tape tape-r1">Open Source</span>
          <span class="tape tape-r2">Self-Hosted</span>
        </div>
      </div>

      <aside class="hud-panel" aria-label="System status">
        <div class="panel-header">
          <span class="panel-header-label">SYS // CM-01</span>
          <div class="led-row" aria-hidden="true">
            <div class="led led-g"></div>
            <div class="led led-g"></div>
            <div class="led led-y"></div>
            <div class="led led-off"></div>
            <div class="led led-off"></div>
            <span class="led-text">ONLINE</span>
          </div>
        </div>

        <div class="panel-body">
          <div class="panel-hazard-strip" aria-hidden="true"></div>

          <div class="panel-section">
            <div class="panel-label">// disciplines</div>
            <div class="tags" aria-label="Project disciplines">
              <a href="{{ '/tags/software/' | url }}" class="tag tag-software">Software</a>
              <a href="{{ '/tags/music/' | url }}" class="tag tag-music">Music</a>
              <a href="{{ '/tags/hardware/' | url }}" class="tag tag-hardware">Hardware</a>
              <a href="{{ '/tags/vr/' | url }}" class="tag tag-vr">VR</a>
              <a href="{{ '/tags/open-source/' | url }}" class="tag tag-open-source">Open Source</a>
            </div>
          </div>

          <div class="panel-rule" aria-hidden="true"></div>

          <div class="panel-section">
            <div class="panel-label">// stack</div>
            <div class="skill-cells" role="list" aria-label="Core skills">
              {%- for group in skillGroups %}
                {%- for skill in group.skills %}
                  {%- if skill.featured %}
                  <a href="{{ ('/skills/' + skill.id) | url }}" class="skill-cell skill-cell-{{ skill.level }}" role="listitem">{{ skill.label }}</a>
                  {%- endif %}
                {%- endfor %}
              {%- endfor %}
            </div>
          </div>
        </div>

        <div class="panel-footer-stripe" aria-hidden="true"></div>
      </aside>

    </div><!-- /hud-bottom -->
  </div><!-- /hud -->

  <a href="#featured" class="hud-scroll" aria-label="Scroll to featured projects">
    <div class="scroll-line" aria-hidden="true"></div>
    <span>Featured</span>
  </a>

</section>

<!-- ════════════════════════════
     FEATURED PROJECTS STRIP
     ════════════════════════════ -->
<section id="featured" aria-label="Featured projects">

  <div class="stripe stripe-medium" role="presentation" aria-hidden="true"></div>

  <div class="hero-cards-strip">
    <div class="hero-cards-inner constrained-inner">
      {%- for project in collections.projects | sort(true, false, "data.year") %}
      {%- if project.data.featured %}
      <div class="mini-card">
        <div class="mini-card-num">{{ project.data.order | padZero }} //</div>
        <a href="{{ project.url | url }}" class="mini-card-title mini-card-link" aria-label="{{ project.data.title }} project">{{ project.data.title }}</a>
        <div class="mini-card-desc">{{ project.data.summary }}</div>
        <div class="mini-card-tags">
          {%- for tag in project.data.projectTags %}
          <a href="{{ ('/tags/' + tag) | url }}" class="tag tag-{{ tag }}" aria-label="Browse {{ tag | tagName }} projects">{{ tag | tagName }}</a>
          {%- endfor %}
        </div>
      </div>
      {%- endif %}
      {%- endfor %}
    </div>

    <a href="{{ '/projects/' | url }}" class="mini-card-view-all" aria-label="View all projects">
      View all projects
    </a>
  </div>

</section>
</main>
